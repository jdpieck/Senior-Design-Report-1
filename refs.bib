@thesis{ValentinaThesis,
  title = {Design, {{Fabrication}}, and {{Testing}} of a {{Scaled-Up}}, {{High-Effectiveness Microchannel Polymer Heat Exchanger}} for {{Secondary Loop Applications}} in {{HVAC Systems}}},
  author = {Arévalo-Arredondo, Valentina},
  date = {2024},
  institution = {UC Davis},
  url = {https://escholarship.org/uc/item/1hj347qv},
  urldate = {2026-02-14},
  abstract = {The transition to low-global warming potential (GWP) refrigerants in HVAC systems is crucial for minimizing environmental impact. However, many such refrigerants pose safety concerns, like flammability and toxicity. To mitigate these risks, one viable solution is to isolate the refrigerant system from occupied spaces using a secondary loop system, which requires high-effectiveness heat exchangers.This work presents the design, fabrication, and testing of a 5-kW (1.5-ton) nominal Microchannel Polymer Heat Exchanger (MPHX), a counter-flow heat exchanger fabricated using Stereolithography (SLA) 3D printing technology. This design builds upon the second generation of the MPHX described in Emily Fricke’s PhD dissertation [1]. Experimental results show an average deviation of less than 4\% from an analytical model of the MPHX, across a range of conditions, with heat transfer rates from 2,140 to 4,780 W and effectiveness between 0.63 and 0.83 in cooling mode, thus validating the model. When compared with a commercial 5.3-kW (1.5-ton) chilled water coil [2] under similar testing conditions and equivalent air-side pressure drops, the 3D-Printed MPHX demonstrated effectiveness comparable to that of the commercial coil. This work also outlines the initial steps toward transitioning the MPHX manufacturing to injection molding (IM), specifically for data center cooling applications. The IM version incorporates an enhanced geometry, including a reduction in water channel height, which is expected to improve heat transfer performance. As a result, with the same cross-sectional area as the 3D-printed MPHX, the IM version is predicted to achieve effectiveness ranging from 0.76 to 0.95 (a 20\% increase over the commercial coil) and heat transfer rates between 2,580 and 4,230 W, under same testing conditions.},
  langid = {english},
  file = {C:\Users\patri\Zotero\storage\6FMZ6Y6M\1hj347qv.html}
}

